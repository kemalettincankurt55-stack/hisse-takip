# Örnek ortam değişkenleri — bu dosyayı `.env` olarak kopyalayıp değerleri doldurun.
# Expo'da yalnızca EXPO_PUBLIC_ önekli değişkenler uygulamaya gömülür.

# Twelve Data (BIST + ABD fiyat/teknik veri) — https://twelvedata.com/account/api-keys
# Anahtar formatı: noktasız ~32 karakter alfanümerik (örn. a1b2c3d4e5f6a7b8c9d0...)
EXPO_PUBLIC_TWELVE_DATA_API_KEY=

# Sosyal medya proxy adresi (varsayılan: http://localhost:8787)
# Üretimde serverless proxy URL'inizi yazın.
EXPO_PUBLIC_SOCIAL_PROXY=http://localhost:8787

# Reddit (opsiyonel, sosyal proxy için) — https://www.reddit.com/prefs/apps
# Bunlar PROXY tarafında kullanılır (client'a gömülmez), EXPO_PUBLIC_ öneki YOK.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
